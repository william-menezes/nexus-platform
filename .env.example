# .env.example — copiar para .env e preencher com valores reais
# .env está no .gitignore e NUNCA deve ser commitado

# API
PORT=3000
NODE_ENV=development

# Supabase (Settings → API no dashboard supabase.com)
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...   # ⚠️ apenas no backend — nunca expor no frontend

# PostgreSQL via Supabase (Settings → Database → Connection string → Transaction)
DATABASE_URL=postgresql://postgres.SEU-PROJETO:SENHA@aws-0-REGIAO.pooler.supabase.com:6543/postgres

# CORS
FRONTEND_URL=http://localhost:4200

# Angular — variáveis públicas (Vercel lê com prefixo NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# WhatsApp — Evolution API (Semana 4)
EVOLUTION_API_URL=https://evolution-api-xxx.railway.app
EVOLUTION_API_KEY=sua-chave-secreta
WHATSAPP_INSTANCE=nexus-tenant

# Pagamentos — Asaas (Semana 4)
ASAAS_API_KEY=seu-token-sandbox
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
